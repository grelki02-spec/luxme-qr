<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LUXME Experience</title>
  <style>
    body {
      margin: 0;
      padding: 20px;
      background: #e9e9ec;
      font-family: Georgia, "Times New Roman", serif;
      color: #2f2b28;
    }

    .page {
      max-width: 620px;
      margin: 0 auto;
      background: #ece6dd;
      padding: 34px 30px 0 30px;
      box-sizing: border-box;
    }

    h1 {
      margin: 0 0 26px 0;
      text-align: center;
      font-size: 30px;
      line-height: 1.15;
      font-weight: 700;
      color: #1f1b18;
    }

    .intro {
      text-align: center;
      font-size: 15px;
      line-height: 1.6;
      margin: 0 auto 30px auto;
      max-width: 520px;
    }

    .section {
      margin: 0 0 24px 0;
    }

    .section-title {
      font-size: 13px;
      letter-spacing: 3px;
      text-transform: uppercase;
      font-weight: 700;
      margin: 0 0 8px 0;
    }

    .item {
      font-size: 14px;
      line-height: 1.5;
      margin: 0;
    }

    .contact {
      text-align: center;
      font-size: 12px;
      margin: 22px 0 24px 0;
    }

    .image-box {
      position: relative;
      margin: 0 -30px 0 -30px;
    }

    .main-image {
      width: 100%;
      display: block;
      opacity: 0.45;
    }

    .logo-overlay {
      position: absolute;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      width: 100px;
      height: auto;
    }

    @media (max-width: 700px) {
      body {
        padding: 12px;
      }

      .page {
        max-width: 100%;
        padding: 24px 20px 0 20px;
      }

      h1 {
        font-size: 24px;
      }

      .intro {
        font-size: 13px;
        line-height: 1.5;
        margin-bottom: 24px;
      }

      .section {
        margin-bottom: 20px;
      }

      .section-title {
        font-size: 11px;
        letter-spacing: 2.5px;
      }

      .item {
        font-size: 12px;
        line-height: 1.4;
      }

      .contact {
        font-size: 11px;
        margin: 18px 0 20px 0;
      }

      .image-box {
        margin: 0 -20px 0 -20px;
      }

      .logo-overlay {
        width: 82px;
        bottom: 14px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <h1 id="title"></h1>

    <div class="intro" id="desc"></div>

    <div class="section">
      <div class="section-title">MAIN RESTAURANT</div>
      <div id="restaurant"></div>
    </div>

    <div class="section">
      <div class="section-title">FOOD COURT</div>
      <div id="food"></div>
    </div>

    <div class="section">
      <div class="section-title">A LA CARTE RESTAURANTS</div>
      <div id="alacarte"></div>
    </div>

    <div class="section">
      <div class="section-title">BARS</div>
      <div id="bars"></div>
    </div>

    <div class="section">
      <div class="section-title">WELLNESS & ACTIVITIES</div>
      <div id="wellness"></div>
    </div>

    <div class="contact" id="contact"></div>

    <div class="image-box">
      <img src="hotel.jpg" alt="Hotel View" class="main-image">
      <img src="logo.png" alt="LUXME Logo" class="logo-overlay">
    </div>
  </div>

  <script>
    fetch('data.json')
      .then(function(res) {
        return res.json();
      })
      .then(function(data) {
        document.getElementById('title').textContent = data.title || '';
        document.getElementById('desc').textContent = data.description || '';

        function fill(id, arr) {
          var el = document.getElementById(id);
          el.innerHTML = '';
          if (!arr || !arr.length) return;

          arr.forEach(function(item) {
            var row = document.createElement('div');
            row.className = 'item';
            row.textContent = item;
            el.appendChild(row);
          });
        }

        fill('restaurant', data.main_restaurant);
        fill('food', data.food_court);
        fill('alacarte', data.alacarte);
        fill('bars', data.bars);
        fill('wellness', data.wellness);

        document.getElementById('contact').textContent =
          'Contact via WhatsApp: ' + (data.contact || '');
      })
      .catch(function(error) {
        console.error('Error loading data.json:', error);
      });
  </script>
</body>
</html>
