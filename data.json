<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LUXME Experience</title>

  <style>
    body {
      margin: 0;
      padding: 20px;
      background: #e9e9ec;
      font-family: Georgia, serif;
      color: #2f2f2f;
    }

    .page {
      max-width: 820px;
      margin: 0 auto;
      background: #ece6dd;
      padding: 40px 36px;
    }

    h1 {
      margin: 0 0 24px 0;
      font-size: 28px;
    }

    .intro {
      text-align: center;
      margin-bottom: 30px;
      line-height: 1.6;
    }

    .section {
      margin: 20px 0;
    }

    .section-title {
      font-size: 13px;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 10px;
      font-weight: bold;
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .list-item {
      margin: 5px 0;
    }

    /* 📸 IMAGE + LOGO */
    .image-box {
      position: relative;
      margin-top: 30px;
    }

    .main-image {
      width: 100%;
      display: block;
    }

    .logo-overlay {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 120px;
    }

    .contact {
      margin-top: 25px;
      text-align: center;
      font-weight: bold;
    }

  </style>
</head>

<body>

<div class="page">

  <h1 id="title"></h1>

  <div class="intro" id="desc"></div>

  <div class="section">
    <div class="section-title">Main Restaurant</div>
    <ul id="restaurant"></ul>
  </div>

  <div class="section">
    <div class="section-title">Food Court</div>
    <ul id="foodcourt"></ul>
  </div>

  <div class="section">
    <div class="section-title">À La Carte Restaurants</div>
    <ul id="alacarte"></ul>
  </div>

  <div class="section">
    <div class="section-title">Bars</div>
    <ul id="bars"></ul>
  </div>

  <div class="section">
    <div class="section-title">Wellness & Activities</div>
    <ul id="wellness"></ul>
  </div>

  <div class="contact" id="contact"></div>

  <!-- 📸 ΦΩΤΟ + LOGO -->
  <div class="image-box">
    <img src="hotel.jpg" class="main-image">
    <img src="logo.png" class="logo-overlay">
  </div>

</div>

<script>
fetch('data.json')
.then(res => res.json())
.then(data => {

document.getElementById('title').innerText = data.title;
document.getElementById('desc').innerText = data.description;

function fillList(id, items){
  let ul = document.getElementById(id);
  ul.innerHTML = "";
  if(!items) return;

  items.forEach(item => {
    let li = document.createElement("li");
    li.className = "list-item";
    li.innerText = item;
    ul.appendChild(li);
  });
}

fillList("restaurant", data.main_restaurant);
fillList("foodcourt", data.food_court);
fillList("alacarte", data.alacarte_restaurants);
fillList("bars", data.bars);
fillList("wellness", data.wellness);

if(data.contact){
  document.getElementById('contact').innerHTML =
    "Contact via WhatsApp: <a href='https://wa.me/" + data.contact + "'>" + data.contact + "</a>";
}

});
</script>

</body>
</html>
