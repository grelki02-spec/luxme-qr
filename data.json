<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LUXME Experience</title>
  <style>
    body {
      margin: 0;
      padding: 18px;
      background: #e9e9ec;
      font-family: Georgia, "Times New Roman", serif;
      color: #2f2b28;
    }

    .page {
      max-width: 540px;
      margin: 0 auto;
      background: #ece6dd;
      padding: 26px 22px 0 22px;
      box-sizing: border-box;
    }

    h1 {
      margin: 0 0 26px 0;
      text-align: center;
      font-size: 25px;
      line-height: 1.2;
      font-weight: 700;
      color: #1f1b18;
    }

    .intro {
      text-align: center;
      font-size: 14px;
      line-height: 1.45;
      margin: 0 auto 22px auto;
      max-width: 430px;
    }

    .section {
      margin: 0 0 18px 0;
    }

    .section-title {
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      font-weight: 700;
      margin: 0 0 6px 0;
    }

    .section-title.mixed {
      text-transform: none;
      letter-spacing: 2.4px;
    }

    .item {
      font-size: 12px;
      line-height: 1.35;
      margin: 0;
    }

    .space {
      height: 14px;
    }

    .contact {
      text-align: center;
      font-size: 11px;
      margin: 16px 0 24px 0;
    }

    .image-box {
      position: relative;
      margin: 0 -22px 0 -22px;
    }

    .main-image {
      width: 100%;
      display: block;
      opacity: 0.42;
    }

    .logo-overlay {
      position: absolute;
      left: 50%;
      bottom: 14px;
      transform: translateX(-50%);
      width: 96px;
      height: auto;
    }

    @media (max-width: 600px) {
      body {
        padding: 12px;
      }

      .page {
        max-width: 100%;
        padding: 22px 18px 0 18px;
      }

      h1 {
        font-size: 22px;
      }

      .intro {
        font-size: 13px;
      }

      .section-title {
        font-size: 11px;
        letter-spacing: 3px;
      }

      .item {
        font-size: 11px;
      }

      .image-box {
        margin: 0 -18px 0 -18px;
      }

      .logo-overlay {
        width: 82px;
        bottom: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <h1>Welcome to your LUXME Experience</h1>

    <div class="intro">
      Thank you for choosing our five-star destination. By scanning this QR code, you enjoy seamless access to our curated services, dining concepts and wellness experiences – designed for effortless luxury and comfort.<br>
      Our team is at your service at all times. Enjoy every moment of your stay.
    </div>

    <div class="section">
      <div class="section-title">MAIN RESTAURANT</div>
      <p class="item">Breakfast: 07:15 – 10:30</p>
      <p class="item">Lunch: 12:30 – 14:30</p>
      <p class="item">Dinner: 18:00 – 21:30</p>
      <p class="item">Late Night Snack: 23:00 – 01:00</p>
    </div>

    <div class="section">
      <div class="section-title">FOOD COURT</div>
      <p class="item">Pool Bar: Creperie &amp; Gelaterie 11:00 – 18:00</p>
      <p class="item">Pool Bar Lunch: 12:30 – 15:30</p>
      <p class="item">Pool Bar Light Fare: 12:30 – 18:00</p>
      <p class="item">Pool Bar Tavernaki: 19:00 – 22:00</p>
    </div>

    <div class="space"></div>

    <div class="section">
      <div class="section-title mixed">A La Carte Restaurants (Reservation required)</div>
      <p class="item">Finikia – Italian Hotstone</p>
      <p class="item">1930s – Lobsterie</p>
      <p class="item">Tavernaki – Greek Taverna</p>
      <p class="item">Asiana – Asian Cuisine</p>
    </div>

    <div class="section">
      <div class="section-title">BARS</div>
      <p class="item">Beach Bar: 11:00 – 18:00</p>
      <p class="item">Garden &amp; Pool Bar: 11:00 – 18:00</p>
      <p class="item">1930s Bar restaurant</p>
      <p class="item">Lobby Bar: 10:00 – 01:00</p>
      <div class="space"></div>
      <p class="item">Afternoon Tea: 15:30 – 17:00</p>
      <p class="item">PATISSERIE &amp; CHOCOLATERIE: 19:30 – 21:30</p>
    </div>

    <div class="space"></div>

    <div class="section">
      <div class="section-title">WELLNESS &amp; ACTIVITIES</div>
      <p class="item">Spa: 10:00 – 18:00 (Sundays closed)</p>
      <p class="item">Gym: 07:00 – 20:00</p>
      <p class="item">Grecoland: 10:00 – 17:00 (Saturdays closed)</p>
    </div>

    <div class="contact">
      Contact via WhatsApp: +30 694 900 0586
    </div>

    <div class="image-box">
      <img src="hotel.jpg" alt="Hotel View" class="main-image">
      <img src="logo.png" alt="LUXME Logo" class="logo-overlay">
    </div>

  </div>
</body>
</html>
